  "item": [
    {
      "name": "01 - Authentication (user.partner)",
      "item": [
        {
          "name": "Remember Me - TEST_USER_001",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has token property\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "    pm.expect(jsonData.token).to.be.a('string');",
                  "    pm.expect(jsonData.token).to.not.be.empty;",
                  "    pm.collectionVariables.set('authToken', jsonData.token);",
                  "    console.log('Auth token saved:', jsonData.token.substring(0, 20) + '...');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api.user.partner.rememberMe?code=TEST_USER_001",
              "host": ["{{baseUrl}}"],
              "path": ["api.user.partner.rememberMe"],
              "query": [
                {
                  "key": "code",
                  "value": "TEST_USER_001",
                  "description": "Unique partner code"
                }
              ]
            },
            "description": "Authenticate with existing partner code and get JWT token"
          }
        },
        {
          "name": "Remember Me - New User (Auto-Create)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"New user auto-created with token\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "    pm.expect(jsonData.token).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api.user.partner.rememberMe?code=NEW_USER_{{$timestamp}}",
              "host": ["{{baseUrl}}"],
              "path": ["api.user.partner.rememberMe"],
              "query": [
                {
                  "key": "code",
                  "value": "NEW_USER_{{$timestamp}}"
